n                \n                <div class=\"elementskit-card \">\n                    <div class=\"elementskit-card-header\" id=\"primaryHeading-8-f7919d9\">\n                        <a href=\"#collapse-6f582c26a3a7193c207f\" class=\"ekit-accordion--toggler elementskit-btn-link collapsed\" data-ekit-toggle=\"collapse\" data-target=\"#Collapse-6f582c26a3a7193c207f\" aria-expanded=\"false\" aria-controls=\"Collapse-6f582c26a3a7193c207f\">\n                            \n                            <span class=\"ekit-accordion-title\">How far in advance should I book?<\/span>\n\n                            \n                                <div class=\"ekit_accordion_icon_group\">\n                                    <div class=\"ekit_accordion_normal_icon\">\n                                        <!-- Normal Icon -->\n\t\t\t\t\t\t\t\t\t\t<i class=\"jki jki-plus-light\"><\/i>                                    <\/div>\n\n                                    <div class=\"ekit_accordion_active_icon\">\n                                        <!-- Active Icon -->\n\t\t\t\t\t\t\t\t\t\t<i class=\"jki jki-x-line\"><\/i>                                    <\/div>\n                                <\/div>\n\n                            \n                                                    <\/a>\n                    <\/div>\n\n                    <div id=\"Collapse-6f582c26a3a7193c207f\" class=\" collapse\" aria-labelledby=\"primaryHeading-8-f7919d9\" data-parent=\"#accordion-6a3a7193c207f\">\n\n                        <div class=\"elementskit-card-body ekit-accordion--content\">\n                            <p>We recommend booking 1\u20133 months in advance for regular seasons and 3\u20136 months ahead for peak travel periods.<\/p>                        <\/div>\n\n                    <\/div>\n\n                <\/div><!-- .elementskit-card END -->\n\n                \n                <div class=\"elementskit-card \">\n                    <div class=\"elementskit-card-heade